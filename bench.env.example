# bench.env.example — 複製成 bench.env 並填你自己的值：cp bench.env.example bench.env
# bench.env 含明文憑證 → chmod 600、已被 .gitignore（勿提交）。
# 用法：source bench.env && source ns_verify.sh   （access 函式在 ns_verify.sh）
# ════════════════════════════════════════════════════════════════════
# 4-node 驗證 bench 的 access inventory（source-safe：填值前直接 source 也不報錯）。
# 角色 ↔ legacy 變數名對照：
#   DUT=受測 CPE ／ FLYBOX=upstream gateway ／ PC2(armA)=observer(WAN 抓包+harness host)
#   ／ armB=LAN client（隔離於 netns，封包強制穿 DUT）

# ── DUT（device under test：受測 CPE）──
DUT=192.168.1.1                          # LAN 管理 IP（通用預設，可留）
DUT_WAN="REPLACE_ME_DUT_WAN_IP"          # DUT WAN 側 IP
DUT_WAN_IF=eth0                          # DUT 自己的 WAN iface
DUT_LAN_MAC="REPLACE_ME_DUT_LAN_MAC"     # DUT LAN MAC（ARP 核對用）
# access: ssh root@$DUT → dut() helper

# ── upstream gateway（模擬 ISP；變數名 FLYBOX=legacy）──
FLYBOX="REPLACE_ME_UPSTREAM_GW_IP"
# access: ssh root@$FLYBOX → flybox() helper

# ── observer（WAN 端抓包 + LAN harness host；變數名 PC2=legacy）──
PC2="REPLACE_ME_OBSERVER_IP"
PC2_USER="REPLACE_ME_OBSERVER_USER"
PC2_LOGIN_PW='REPLACE_ME_LOGIN_PW'
PC2_ROOT_PW='REPLACE_ME_ROOT_PW'         # sudo -S 提權（可能 ≠ 登入）
PC2_IF="REPLACE_ME_OBSERVER_WAN_IFACE"
# access: sshpass -p "$PC2_LOGIN_PW" ssh $PC2_USER@$PC2 → pc2()/pc2root()

# ── LAN client 臂（隔離於 netns，封包強制穿 DUT；變數名 armB=legacy）──
ARMB_IF="REPLACE_ME_LAN_CLIENT_IFACE"
ARMB_MAC="REPLACE_ME_LAN_CLIENT_MAC"
ARMB_IP=192.168.1.3
ARMB_NM_CON="Wired connection 2"         # NetworkManager 連線名（回復用）
# access: sudo sh /tmp/pc2_lan_netns.sh exec <cmd>

ARMA_IF="REPLACE_ME_OBSERVER_WAN_IFACE"  # = PC2_IF（observer SSH 命脈）
ARMA_IP="REPLACE_ME_OBSERVER_IP"         # = PC2

# ── 第二 client（legacy，選用）──
LAN_IF=eth0
WAN_IF=eth2
LAN_CLIENT_IP=192.168.1.2
LAN_CLIENT_MAC="REPLACE_ME_SECOND_CLIENT_MAC"

# ── 設備識別（供 check_secrets 掃描你的公開檔有無洩漏型號/廠商/序號）──
DEV_BOARD="REPLACE_ME_BOARD_MODEL_OR_SERIAL"
DEV_SOC="REPLACE_ME_SOC_MODEL"
DEV_VENDOR="REPLACE_ME_VENDOR_OR_IMAGE_NAME"
